<xml xmlns="https://developers.google.com/blockly/xml">

  <variables>
    <variable id="window_size">window_size</variable>
    <variable id="count_0_4">count_0_4</variable>
    <variable id="count_6_9">count_6_9</variable>
    <variable id="pct_0_4">pct_0_4</variable>
    <variable id="pct_6_9">pct_6_9</variable>
    <variable id="consecutive_6_9">consecutive_6_9</variable>
    <variable id="consecutive_0_3">consecutive_0_3</variable>
    <variable id="phase">phase</variable>
    <variable id="digit">digit</variable>
    <variable id="old_digit">old_digit</variable>
    <variable id="ready_to_trade">ready_to_trade</variable>
  </variables>

  <!-- Initialize variables -->
  <block type="variables_set" id="init_window" x="20" y="20">
    <field name="VAR" id="window_size">window_size</field>
    <value name="VALUE">
      <block type="math_number">
        <field name="NUM">100</field>
      </block>
    </value>
    <next>
      <block type="variables_set" id="init_count_0_4">
        <field name="VAR" id="count_0_4">count_0_4</field>
        <value name="VALUE">
          <block type="math_number">
            <field name="NUM">0</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="init_count_6_9">
            <field name="VAR" id="count_6_9">count_6_9</field>
            <value name="VALUE">
              <block type="math_number">
                <field name="NUM">0</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="init_consecutive_6_9">
                <field name="VAR" id="consecutive_6_9">consecutive_6_9</field>
                <value name="VALUE">
                  <block type="math_number">
                    <field name="NUM">0</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="init_consecutive_0_3">
                    <field name="VAR" id="consecutive_0_3">consecutive_0_3</field>
                    <value name="VALUE">
                      <block type="math_number">
                        <field name="NUM">0</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="init_phase">
                        <field name="VAR" id="phase">phase</field>
                        <value name="VALUE">
                          <block type="text">
                            <field name="TEXT">WAIT_6_9_STREAK</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="init_ready">
                            <field name="VAR" id="ready_to_trade">ready_to_trade</field>
                            <value name="VALUE">
                              <block type="logic_boolean">
                                <field name="BOOL">FALSE</field>
                              </block>
                            </value>
                            <next>
                              <!-- Main tick loop -->
                              <block type="trade_definition" id="main_trade" x="20" y="300">
                                <statement name="INITIALIZATION">
                                  <!-- put initialization blocks here if needed -->
                                </statement>

                                <statement name="SUBMARKET">
                                  <!-- choose synthetic index / market here -->
                                </statement>

                                <statement name="TRADEOPTIONS">
                                  <!-- choose contract type, duration, stake, symbol -->
                                </statement>

                                <statement name="AFTER_PURCHASE">
                                  <!-- trade result handling if needed -->
                                </statement>

                                <statement name="BEFORE_PURCHASE">
                                  <block type="controls_if" id="on_tick_logic">
                                    <value name="IF0">
                                      <block type="logic_boolean">
                                        <field name="BOOL">TRUE</field>
                                      </block>
                                    </value>
                                    <statement name="DO0">
                                      <!-- 1) Get current digit -->
                                      <block type="variables_set" id="set_digit">
                                        <field name="VAR" id="digit">digit</field>
                                        <value name="VALUE">
                                          <block type="text">
                                            <field name="TEXT">last_tick_digit</field>
                                          </block>
                                        </value>
                                        <next>
                                          <!-- 2) Update rolling counts -->
                                          <block type="controls_if" id="count_0_4_if">
                                            <value name="IF0">
                                              <block type="logic_compare">
                                                <field name="OP">LTE</field>
                                                <value name="A">
                                                  <block type="variables_get">
                                                    <field name="VAR" id="digit">digit</field>
                                                  </block>
                                                </value>
                                                <value name="B">
                                                  <block type="math_number">
                                                    <field name="NUM">4</field>
                                                  </block>
                                                </value>
                                              </block>
                                            </value>
                                            <statement name="DO0">
                                              <block type="math_change">
                                                <field name="VAR" id="count_0_4">count_0_4</field>
                                                <value name="DELTA">
                                                  <block type="math_number">
                                                    <field name="NUM">1</field>
                                                  </block>
                                                </value>
                                              </block>
                                            </statement>
                                            <next>
                                              <block type="controls_if" id="count_6_9_if">
                                                <value name="IF0">
                                                  <block type="logic_or">
                                                    <value name="A">
                                                      <block type="logic_compare">
                                                        <field name="OP">GTE</field>
                                                        <value name="A">
                                                          <block type="variables_get">
                                                            <field name="VAR" id="digit">digit</field>
                                                          </block>
                                                        </value>
                                                        <value name="B">
                                                          <block type="math_number">
                                                            <field name="NUM">6</field>
                                                          </block>
                                                        </value>
                                                      </block>
                                                    </value>
                                                    <value name="B">
                                                      <block type="logic_compare">
                                                        <field name="OP">LTE</field>
                                                        <value name="A">
                                                          <block type="variables_get">
                                                            <field name="VAR" id="digit">digit</field>
                                                          </block>
                                                        </value>
                                                        <value name="B">
                                                          <block type="math_number">
                                                            <field name="NUM">9</field>
                                                          </block>
                                                        </value>
                                                      </block>
                                                    </value>
                                                  </block>
                                                </value>
                                                <statement name="DO0">
                                                  <block type="math_change">
                                                    <field name="VAR" id="count_6_9">count_6_9</field>
                                                    <value name="DELTA">
                                                      <block type="math_number">
                                                        <field name="NUM">1</field>
                                                      </block>
                                                    </value>
                                                  </block>
                                                </statement>
                                                <next>
                                                  <!-- 3) Calculate percentages -->
                                                  <block type="variables_set" id="calc_pct_0_4">
                                                    <field name="VAR" id="pct_0_4">pct_0_4</field>
                                                    <value name="VALUE">
                                                      <block type="math_arithmetic">
                                                        <field name="OP">MULTIPLY</field>
                                                        <value name="A">
                                                          <block type="math_arithmetic">
                                                            <field name="OP">DIVIDE</field>
                                                            <value name="A">
                                                              <block type="variables_get">
                                                                <field name="VAR" id="count_0_4">count_0_4</field>
                                                              </block>
                                                            </value>
                                                            <value name="B">
                                                              <block type="variables_get">
                                                                <field name="VAR" id="window_size">window_size</field>
                                                              </block>
                                                            </value>
                                                          </block>
                                                        </value>
                                                        <value name="B">
                                                          <block type="math_number">
                                                            <field name="NUM">100</field>
                                                          </block>
                                                        </value>
                                                      </block>
                                                    </value>
                                                    <next>
                                                      <block type="variables_set" id="calc_pct_6_9">
                                                        <field name="VAR" id="pct_6_9">pct_6_9</field>
                                                        <value name="VALUE">
                                                          <block type="math_arithmetic">
                                                            <field name="OP">MULTIPLY</field>
                                                            <value name="A">
                                                              <block type="math_arithmetic">
                                                                <field name="OP">DIVIDE</field>
                                                                <value name="A">
                                                                  <block type="variables_get">
                                                                    <field name="VAR" id="count_6_9">count_6_9</field>
                                                                  </block>
                                                                </value>
                                                                <value name="B">
                                                                  <block type="variables_get">
                                                                    <field name="VAR" id="window_size">window_size</field>
                                                                  </block>
                                                                </value>
                                                              </block>
                                                            </value>
                                                            <value name="B">
                                                              <block type="math_number">
                                                                <field name="NUM">100</field>
                                                              </block>
                                                            </value>
                                                          </block>
                                                        </value>
                                                        <next>
                                                          <!-- 4) Check percentage filters -->
                                                          <block type="controls_if" id="filter_check">
                                                            <value name="IF0">
                                                              <block type="logic_and">
                                                                <value name="A">
                                                                  <block type="logic_compare">
                                                                    <field name="OP">LT</field>
                                                                    <value name="A">
                                                                      <block type="variables_get">
                                                                        <field name="VAR" id="pct_0_4">pct_0_4</field>
                                                                      </block>
                                                                    </value>
                                                                    <value name="B">
                                                                      <block type="math_number">
                                                                        <field name="NUM">10</field>
                                                                      </block>
                                                                    </value>
                                                                  </block>
                                                                </value>
                                                                <value name="B">
                                                                  <block type="logic_compare">
                                                                    <field name="OP">GT</field>
                                                                    <value name="A">
                                                                      <block type="variables_get">
                                                                        <field name="VAR" id="pct_6_9">pct_6_9</field>
                                                                      </block>
                                                                    </value>
                                                                    <value name="B">
                                                                      <block type="math_number">
                                                                        <field name="NUM">10.5</field>
                                                                      </block>
                                                                    </value>
                                                                  </block>
                                                                </value>
                                                              </block>
                                                            </value>
                                                            <statement name="DO0">
                                                              <!-- 5) Phase logic -->
                                                              <block type="controls_if" id="phase_logic">
                                                                <value name="IF0">
                                                                  <block type="logic_compare">
                                                                    <field name="OP">EQ</field>
                                                                    <value name="A">
                                                                      <block type="variables_get">
                                                                        <field name="VAR" id="phase">phase</field>
                                                                      </block>
                                                                    </value>
                                                                    <value name="B">
                                                                      <block type="text">
                                                                        <field name="TEXT">WAIT_6_9_STREAK</field>
                                                                      </block>
                                                                    </value>
                                                                  </block>
                                                                </value>
                                                                <statement name="DO0">
                                                                  <!-- Track four consecutive 6-9 digits -->
                                                                  <block type="controls_if" id="streak_6_9">
                                                                    <value name="IF0">
                                                                      <block type="logic_or">
                                                                        <value name="A">
                                                                          <block type="logic_compare">
                                                                            <field name="OP">GTE</field>
                                                                            <value name="A">
                                                                              <block type="variables_get">
                                                                                <field name="VAR" id="digit">digit</field>
                                                                              </block>
                                                                            </value>
                                                                            <value name="B">
                                                                              <block type="math_number">
                                                                                <field name="NUM">6</field>
                                                                              </block>
                                                                            </value>
                                                                          </block>
                                                                        </value>
                                                                        <value name="B">
                                                                          <block type="logic_compare">
                                                                            <field name="OP">LTE</field>
                                                                            <value name="A">
                                                                              <block type="variables_get">
                                                                                <field name="VAR" id="digit">digit</field>
                                                                              </block>
                                                                            </value>
                                                                            <value name="B">
                                                                              <block type="math_number">
                                                                                <field name="NUM">9</field>
                                                                              </block>
                                                                            </value>
                                                                          </block>
                                                                        </value>
                                                                      </block>
                                                                    </value>
                                                                    <statement name="DO0">
                                                                      <block type="math_change">
                                                                        <field name="VAR" id="consecutive_6_9">consecutive_6_9</field>
                                                                        <value name="DELTA">
                                                                          <block type="math_number">
                                                                            <field name="NUM">1</field>
                                                                          </block>
                                                                        </value>
                                                                      </block>
                                                                    </statement>
                                                                    <statement name="ELSE">
                                                                      <block type="variables_set">
                                                                        <field name="VAR" id="consecutive_6_9">consecutive_6_9</field>
                                                                        <value name="VALUE">
                                                                          <block type="math_number">
                                                                            <field name="NUM">0</field>
                                                                          </block>
                                                                        </value>
                                                                      </block>
                                                                    </statement>
                                                                  </block>
                                                                  <next>
                                                                    <block type="controls_if">
                                                                      <value name="IF0">
                                                                        <block type="logic_compare">
                                                                          <field name="OP">EQ</field>
                                                                          <value name="A">
                                                                            <block type="variables_get">
                                                                              <field name="VAR" id="consecutive_6_9">consecutive_6_9</field>
                                                                            </block>
                                                                          </value>
                                                                          <value name="B">
                                                                            <block type="math_number">
                                                                              <field name="NUM">4</field>
                                                                            </block>
                                                                          </value>
                                                                        </block>
                                                                      </value>
                                                                      <statement name="DO0">
                                                                        <block type="variables_set">
                                                                          <field name="VAR" id="phase">phase</field>
                                                                          <value name="VALUE">
                                                                            <block type="text">
                                                                              <field name="TEXT">WAIT_0_3_CONFIRM</field>
                                                                            </block>
                                                                          </value>
                                                                        </block>
                                                                      </statement>
                                                                    </block>
                                                                  </next>
                                                                </statement>

                                                                <statement name="ELSE">
                                                                  <!-- Confirm two ticks in 0-3 -->
                                                                  <block type="controls_if">
                                                                    <value name="IF0">
                                                                      <block type="logic_compare">
                                                                        <field name="OP">EQ</field>
                                                                        <value name="A">
                                                                          <block type="variables_get">
                                                                            <field name="VAR" id="phase">phase</field>
                                                                          </block>
                                                                        </value>
                                                                        <value name="B">
                                                                          <block type="text">
                                                                            <field name="TEXT">WAIT_0_3_CONFIRM</field>
                                                                          </block>
                                                                        </value>
                                                                      </block>
                                                                    </value>
                                                                    <statement name="DO0">
                                                                      <block type="controls_if">
                                                                        <value name="IF0">
                                                                          <block type="logic_or">
                                                                            <value name="A">
                                                                              <block type="logic_compare">
                                                                                <field name="OP">LTE</field>
                                                                                <value name="A">
                                                                                  <block type="variables_get">
                                                                                    <field name="VAR" id="digit">digit</field>
                                                                                  </block>
                                                                                </value>
                                                                                <value name="B">
                                                                                  <block type="math_number">
                                                                                    <field name="NUM">3</field>
                                                                                  </block>
                                                                                </value>
                                                                              </block>
                                                                            </value>
                                                                            <value name="B">
                                                                              <block type="logic_compare">
                                                                                <field name="OP">EQ</field>
                                                                                <value name="A">
                                                                                  <block type="variables_get">
                                                                                    <field name="VAR" id="digit">digit</field>
                                                                                  </block>
                                                                                </value>
                                                                                <value name="B">
                                                                                  <block type="math_number">
                                                                                    <field name="NUM">0</field>
                                                                                  </block>
                                                                                </value>
                                                                              </block>
                                                                            </value>
                                                                          </block>
                                                                        </value>
                                                                        <statement name="DO0">
                                                                          <block type="math_change">
                                                                            <field name="VAR" id="consecutive_0_3">consecutive_0_3</field>
                                                                            <value name="DELTA">
                                                                              <block type="math_number">
                                                                                <field name="NUM">1</field>
                                                                              </block>
                                                                            </value>
                                                                          </block>
                                                                        </statement>
                                                                        <statement name="ELSE">
                                                                          <block type="variables_set">
                                                                            <field name="VAR" id="consecutive_6_9">consecutive_6_9</field>
                                                                            <value name="VALUE">
                                                                              <block type="math_number">
                                                                                <field name="NUM">0</field>
                                                                              </block>
                                                                            </value>
                                                                          </block>
                                                                        </statement>
                                                                      </block>
                                                                      <next>
                                                                        <block type="controls_if">
                                                                          <value name="IF0">
                                                                            <block type="logic_compare">
                                                                              <field name="OP">EQ</field>
                                                                              <value name="A">
                                                                                <block type="variables_get">
                                                                                  <field name="VAR" id="consecutive_0_3">consecutive_0_3</field>
                                                                                </block>
                                                                              </value>
                                                                              <value name="B">
                                                                                <block type="math_number">
                                                                                  <field name="NUM">2</field>
                                                                                </block>
                                                                              </value>
                                                                            </block>
                                                                          </value>
                                                                          <statement name="DO0">
                                                                            <block type="variables_set">
                                                                              <field name="VAR" id="ready_to_trade">ready_to_trade</field>
                                                                              <value name="VALUE">
                                                                                <block type="logic_boolean">
                                                                                  <field name="BOOL">TRUE</field>
                                                                                </block>
                                                                              </value>
                                                                            </block>
                                                                          </statement>
                                                                        </block>
                                                                      </next>
                                                                    </statement>
                                                                  </block>
                                                                </statement>
                                                              </block>
                                                            </statement>
                                                          </block>
                                                        </next>
                                                      </block>
                                                    </next>
                                                  </block>
                                                </next>
                                              </block>
                                            </next>
                                          </block>
                                        </next>
                                      </block>
                                    </statement>
                                  </block>
                                </statement>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
