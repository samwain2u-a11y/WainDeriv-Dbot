<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.deriv.com/dbot-block">
  <variables>
    <variable>stake</variable>
    <variable>duration</variable>
    <variable>digit</variable>
    <variable>high_digit_count</variable>
    <variable>low_digit_count</variable>
    <variable>total_ticks</variable>
    <variable>high_percentage</variable>
    <variable>low_percentage</variable>
    <variable>consecutive_high</variable>
    <variable>consecutive_low</variable>
    <variable>bot_phase</variable>
    <variable>trade_entered</variable>
  </variables>

  <block type="trade_definition_restart" id="trade_start">
    <field name="CURRENCY">USD</field>
    <next>
      <block type="variable_set" id="init_stake">
        <field name="VAR">stake</field>
        <value name="VALUE">
          <block type="math_number" id="stake_val">
            <field name="NUM">1</field>
          </block>
        </value>
        <next>
          <block type="variable_set" id="init_duration">
            <field name="VAR">duration</field>
            <value name="VALUE">
              <block type="math_number" id="duration_val">
                <field name="NUM">5</field>
              </block>
            </value>
            <next>
              <block type="variable_set" id="init_high_count">
                <field name="VAR">high_digit_count</field>
                <value name="VALUE">
                  <block type="math_number" id="high_count_val">
                    <field name="NUM">0</field>
                  </block>
                </value>
                <next>
                  <block type="variable_set" id="init_low_count">
                    <field name="VAR">low_digit_count</field>
                    <value name="VALUE">
                      <block type="math_number" id="low_count_val">
                        <field name="NUM">0</field>
                      </block>
                    </value>
                    <next>
                      <block type="variable_set" id="init_total">
                        <field name="VAR">total_ticks</field>
                        <value name="VALUE">
                          <block type="math_number" id="total_val">
                            <field name="NUM">0</field>
                          </block>
                        </value>
                        <next>
                          <block type="variable_set" id="init_consecutive_high">
                            <field name="VAR">consecutive_high</field>
                            <value name="VALUE">
                              <block type="math_number" id="cons_high_val">
                                <field name="NUM">0</field>
                              </block>
                            </value>
                            <next>
                              <block type="variable_set" id="init_consecutive_low">
                                <field name="VAR">consecutive_low</field>
                                <value name="VALUE">
                                  <block type="math_number" id="cons_low_val">
                                    <field name="NUM">0</field>
                                  </block>
                                </value>
                                <next>
                                  <block type="variable_set" id="init_phase">
                                    <field name="VAR">bot_phase</field>
                                    <value name="VALUE">
                                      <block type="text" id="phase_waiting">
                                        <field name="TEXT">WAITING</field>
                                      </block>
                                    </value>
                                    <next>
                                      <block type="variable_set" id="init_trade_entered">
                                        <field name="VAR">trade_entered</field>
                                        <value name="VALUE">
                                          <block type="logic_boolean" id="trade_false">
                                            <field name="BOOL">FALSE</field>
                                          </block>
                                        </value>
                                        <next>
                                          <block type="repeat_until" id="main_loop">
                                            <value name="CONDITION">
                                              <block type="logic_boolean" id="loop_false">
                                                <field name="BOOL">FALSE</field>
                                              </block>
                                            </value>
                                            <statement name="DO">
                                              <block type="variable_set" id="extract_digit">
                                                <field name="VAR">digit</field>
                                                <value name="VALUE">
                                                  <block type="math_modulo" id="modulo_calc">
                                                    <value name="DIVIDEND">
                                                      <block type="math_floor" id="floor_close">
                                                        <value name="NUM">
                                                          <block type="bot_candle" id="get_close">
                                                            <field name="PROPERTY">close</field>
                                                            <field name="INDEX">-1</field>
                                                          </block>
                                                        </value>
                                                      </block>
                                                    </value>
                                                    <value name="DIVISOR">
                                                      <block type="math_number" id="mod_10">
                                                        <field name="NUM">10</field>
                                                      </block>
                                                    </value>
                                                  </block>
                                                </value>
                                                <next>
                                                  <block type="math_change" id="increment_total">
                                                    <field name="VAR">total_ticks</field>
                                                    <value name="DELTA">
                                                      <block type="math_number" id="delta_1">
                                                        <field name="NUM">1</field>
                                                      </block>
                                                    </value>
                                                    <next>
                                                      <block type="controls_if" id="check_high_digit">
                                                        <value name="IF0">
                                                          <block type="logic_compare" id="digit_gte_6">
                                                            <field name="OP">GTE</field>
                                                            <value name="A">
                                                              <block type="variables_get" id="get_digit">
                                                                <field name="VAR">digit</field>
                                                              </block>
                                                            </value>
                                                            <value name="B">
                                                              <block type="math_number" id="six">
                                                                <field name="NUM">6</field>
                                                              </block>
                                                            </value>
                                                          </block>
                                                        </value>
                                                        <statement name="DO0">
                                                          <block type="math_change" id="inc_high_count">
                                                            <field name="VAR">high_digit_count</field>
                                                            <value name="DELTA">
                                                              <block type="math_number" id="inc_1">
                                                                <field name="NUM">1</field>
                                                              </block>
                                                            </value>
                                                            <next>
                                                              <block type="math_change" id="inc_consecutive_high">
                                                                <field name="VAR">consecutive_high</field>
                                                                <value name="DELTA">
                                                                  <block type="math_number" id="inc_1_cons">
                                                                    <field name="NUM">1</field>
                                                                  </block>
                                                                </value>
                                                                <next>
                                                                  <block type="variable_set" id="reset_low_cons">
                                                                    <field name="VAR">consecutive_low</field>
                                                                    <value name="VALUE">
                                                                      <block type="math_number" id="zero_low">
                                                                        <field name="NUM">0</field>
                                                                      </block>
                                                                    </value>
                                                                    <next>
                                                                      <block type="controls_if" id="check_phase_waiting">
                                                                        <value name="IF0">
                                                                          <block type="logic_compare" id="phase_eq_waiting">
                                                                            <field name="OP">EQ</field>
                                                                            <value name="A">
                                                                              <block type="variables_get" id="get_phase">
                                                                                <field name="VAR">bot_phase</field>
                                                                              </block>
                                                                            </value>
                                                                            <value name="B">
                                                                              <block type="text" id="text_waiting">
                                                                                <field name="TEXT">WAITING</field>
                                                                              </block>
                                                                            </value>
                                                                          </block>
                                                                        </value>
                                                                        <statement name="DO0">
                                                                          <block type="variable_set" id="set_phase_high">
                                                                            <field name="VAR">bot_phase</field>
                                                                            <value name="VALUE">
                                                                              <block type="text" id="text_high">
                                                                                <field name="TEXT">HIGH_DIGITS</field>
                                                                              </block>
                                                                            </value>
                                                                          </block>
                                                                        </statement>
                                                                        <next>
                                                                          <block type="controls_if" id="check_4_high">
                                                                            <value name="IF0">
                                                                              <block type="logic_compare" id="cons_high_gte_4">
                                                                                <field name="OP">GTE</field>
                                                                                <value name="A">
                                                                                  <block type="variables_get" id="get_cons_high">
                                                                                    <field name="VAR">consecutive_high</field>
                                                                                  </block>
                                                                                </value>
                                                                                <value name="B">
                                                                                  <block type="math_number" id="four">
                                                                                    <field name="NUM">4</field>
                                                                                  </block>
                                                                                </value>
                                                                              </block>
                                                                            </value>
                                                                            <statement name="DO0">
                                                                              <block type="variable_set" id="set_phase_low">
                                                                                <field name="VAR">bot_phase</field>
                                                                                <value name="VALUE">
                                                                                  <block type="text" id="text_low_phase">
                                                                                    <field name="TEXT">LOW_DIGITS</field>
                                                                                  </block>
                                                                                </value>
                                                                              </block>
                                                                            </statement>
                                                                          </block>
                                                                        </next>
                                                                      </block>
                                                                    </next>
                                                                  </block>
                                                                </next>
                                                              </block>
                                                            </next>
                                                          </block>
                                                        </statement>
                                                        <elseif>
                                                          <value name="IF1">
                                                            <block type="logic_compare" id="digit_lte_3">
                                                              <field name="OP">LTE</field>
                                                              <value name="A">
                                                                <block type="variables_get" id="get_digit_2">
                                                                  <field name="VAR">digit</field>
                                                                </block>
                                                              </value>
                                                              <value name="B">
                                                                <block type="math_number" id="three">
                                                                  <field name="NUM">3</field>
                                                                </block>
                                                              </value>
                                                            </block>
                                                          </value>
                                                          <statement name="DO1">
                                                            <block type="math_change" id="inc_low_count">
                                                              <field name="VAR">low_digit_count</field>
                                                              <value name="DELTA">
                                                                <block type="math_number" id="inc_1_low">
                                                                  <field name="NUM">1</field>
                                                                </block>
                                                              </value>
                                                              <next>
                                                                <block type="math_change" id="inc_consecutive_low">
                                                                  <field name="VAR">consecutive_low</field>
                                                                  <value name="DELTA">
                                                                    <block type="math_number" id="inc_1_low_cons">
                                                                      <field name="NUM">1</field>
                                                                    </block>
                                                                  </value>
                                                                  <next>
                                                                    <block type="variable_set" id="reset_high_cons">
                                                                      <field name="VAR">consecutive_high</field>
                                                                      <value name="VALUE">
                                                                        <block type="math_number" id="zero_high">
                                                                          <field name="NUM">0</field>
                                                                        </block>
                                                                      </value>
                                                                      <next>
                                                                        <block type="controls_if" id="check_2_low">
                                                                          <value name="IF0">
                                                                            <block type="logic_and" id="and_check">
                                                                              <value name="A">
                                                                                <block type="logic_compare" id="cons_low_gte_2">
                                                                                  <field name="OP">GTE</field>
                                                                                  <value name="A">
                                                                                    <block type="variables_get" id="get_cons_low">
                                                                                      <field name="VAR">consecutive_low</field>
                                                                                    </block>
                                                                                  </value>
                                                                                  <value name="B">
                                                                                    <block type="math_number" id="two">
                                                                                      <field name="NUM">2</field>
                                                                                    </block>
                                                                                  </value>
                                                                                </block>
                                                                              </value>
                                                                              <value name="B">
                                                                                <block type="logic_compare" id="phase_eq_low">
                                                                                  <field name="OP">EQ</field>
                                                                                  <value name="A">
                                                                                    <block type="variables_get" id="get_phase_2">
                                                                                      <field name="VAR">bot_phase</field>
                                                                                    </block>
                                                                                  </value>
                                                                                  <value name="B">
                                                                                    <block type="text" id="text_low_phase_2">
                                                                                      <field name="TEXT">LOW_DIGITS</field>
                                                                                    </block>
                                                                                  </value>
                                                                                </block>
                                                                              </value>
                                                                            </block>
                                                                          </value>
                                                                          <statement name="DO0">
                                                                            <block type="trade_purchase" id="execute_trade">
                                                                              <field name="AMOUNT">1</field>
                                                                              <field name="DURATION_TYPE">ticks</field>
                                                                              <field name="DURATION">5</field>
                                                                              <next>
                                                                                <block type="variable_set" id="reset_phase">
                                                                                  <field name="VAR">bot_phase</field>
                                                                                  <value name="VALUE">
                                                                                    <block type="text" id="text_reset_phase">
                                                                                      <field name="TEXT">WAITING</field>
                                                                                    </block>
                                                                                  </value>
                                                                                  <next>
                                                                                    <block type="variable_set" id="reset_cons_high">
                                                                                      <field name="VAR">consecutive_high</field>
                                                                                      <value name="VALUE">
                                                                                        <block type="math_number" id="zero_reset_high">
                                                                                          <field name="NUM">0</field>
                                                                                        </block>
                                                                                      </value>
                                                                                      <next>
                                                                                        <block type="variable_set" id="reset_cons_low">
                                                                                          <field name="VAR">consecutive_low</field>
                                                                                          <value name="VALUE">
                                                                                            <block type="math_number" id="zero_reset_low">
                                                                                              <field name="NUM">0</field>
                                                                                            </block>
                                                                                          </value>
                                                                                        </block>
                                                                                      </next>
                                                                                    </block>
                                                                                  </next>
                                                                                </block>
                                                                              </next>
                                                                            </block>
                                                                          </statement>
                                                                        </block>
                                                                      </next>
                                                                    </block>
                                                                  </next>
                                                                </block>
                                                              </next>
                                                            </block>
                                                          </statement>
                                                        </elseif>
                                                      </block>
                                                    </next>
                                                  </block>
                                                </next>
                                              </block>
                                            </statement>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
